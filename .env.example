# Supabase – povinné pro běh aplikace
# Získej v Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Volitelné: pro serverové admin operace (seed, bypass RLS)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Volitelné: whitelist e-mailů s přístupem do /admin (čárkou oddělené)
# ADMIN_ALLOWED_EMAILS=honza@example.com,libor@example.com

# Volitelné, ale doporučené pro SEO/canonical odkazy (produkční URL webu)
# SITE_URL=https://cucobrani.cz
# NEXT_PUBLIC_SITE_URL=https://cucobrani.cz
